{
  "name": "modern-blog",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "dev": "portless blog next dev",
    "build": "bash scripts/build-prod.sh",
    "build:dev": "next build",
    "start": "next start",
    "lint": "eslint app components lib types --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint app components lib types --ext .js,.jsx,.ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:e2e": "playwright test tests/e2e/basic.spec.ts tests/e2e/admin.spec.ts tests/e2e/admin-editor.spec.ts",
    "test:e2e:admin": "playwright test tests/e2e/admin.spec.ts tests/e2e/admin-editor.spec.ts",
    "test:e2e:all": "playwright test",
    "test:e2e:ui": "playwright test --ui tests/e2e/basic.spec.ts",
    "test:integration": "jest --testPathPatterns='__tests__/integration/' --runInBand",
    "test:visual": "tsx scripts/visual-test.ts",
    "check:links": "playwright test tests/e2e/external-links.spec.ts",
    "generate:rss": "tsx scripts/generate-rss.cjs",
    "generate:sitemap": "next-sitemap --config next-sitemap.config.cjs",
    "check:sitemap": "node scripts/check-sitemap.cjs",
    "validate": "npm run format:check && npm run lint && npm run type-check && npm run check:sitemap && npm run test",
    "new:post": "node scripts/new-post.cjs",
    "generate:slideshow": "node scripts/generate-slideshow.cjs",
    "analyze": "ANALYZE=true npm run build",
    "dev:clean": "rm -rf .next && npm run dev",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@next/mdx": "^16.1.1",
    "@sentry/browser": "^10.42.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.16",
    "@types/reveal.js": "^5.2.0",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "date-fns": "^4.1.0",
    "feed": "^5.1.0",
    "gray-matter": "^4.0.3",
    "next": "^16.1.1",
    "next-sitemap": "^4.2.3",
    "posthog-js": "^1.357.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "reading-time": "^1.5.0",
    "rehype-prism-plus": "^2.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-rehype": "^11.1.2",
    "reveal.js": "^5.2.1",
    "tailwindcss": "^4.2.1",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@jest/globals": "^30.2.0",
    "@next/eslint-plugin-next": "^16.1.1",
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "eslint": "^9.34.0",
    "eslint-config-next": "^16.1.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-security": "^4.0.0",
    "husky": "^9.1.7",
    "jest": "^30.1.1",
    "jest-environment-jsdom": "^30.1.1",
    "knip": "^5.64.1",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.52.0"
  },
