{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["scripts/**/*.{ts,tsx,js,jsx}"],
  "project": [
    "**/*.{ts,tsx,js,jsx}",
    "!**/*.test.{ts,tsx,js,jsx}",
    "!**/*.spec.{ts,tsx,js,jsx}",
    "!**/__tests__/**",
    "!**/tests/**"
  ],
  "ignore": [
    "**/*.md",
    "**/*.mdx",
    "**/posts/**",
    "public/**",
    ".next/**",
    "node_modules/**",
    "**/*.d.ts",
    "plans/**",
    "next-sitemap.config.cjs",
    "lib/rss.ts"
  ],
  "ignoreDependencies": [
    "@types/testing-library__jest-dom",
    "eslint-config-next",
    "@jest/globals",
    "@testing-library/user-event",
    "feed"
  ],
  "ignoreBinaries": ["portless"],
  "ignoreExportsUsedInFile": true,
  "eslint": {
    "config": ["eslint.config.js", ".eslintrc.json"]
  },
  "postcss": {
    "config": ["postcss.config.mjs"]
  },
  "tailwind": {
    "config": ["tailwind.config.mjs"]
  }
}
